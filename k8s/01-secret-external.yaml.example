# k8s/01-secret-external.yaml.example
# ============================================================================
# RECOMMENDED for EKS: pulls secrets from AWS Secrets Manager at runtime
# via the External Secrets Operator (ESO), instead of storing them as a
# plain Kubernetes Secret in this repo or in etcd YAML form.
#
# Prerequisites:
#   1. Install External Secrets Operator on the cluster:
#        helm repo add external-secrets https://charts.external-secrets.io
#        helm install external-secrets external-secrets/external-secrets \
#          -n external-secrets --create-namespace
#
#   2. Create ONE secret in AWS Secrets Manager containing all GitMind
#      config as a JSON blob (this is the only place real values live):
#        aws secretsmanager create-secret \
#          --name gitmind/prod/env \
#          --secret-string file://.env.json
#      (.env.json is just your .env converted to a flat JSON object —
#      never commit it)
#
#   3. Give the EKS pod's IAM role (via IRSA) permission to read that
#      secret: attach a policy allowing secretsmanager:GetSecretValue on
#      arn:aws:secretsmanager:<region>:<account-id>:secret:gitmind/prod/env-*
#
#   4. Apply this file (after filling in <placeholders>):
#        kubectl apply -f k8s/01-secret-external.yaml
#
# ESO then creates/refreshes a real `gitmind-secrets` Kubernetes Secret
# automatically, kept in sync with Secrets Manager — rotate the value in
# AWS and it propagates without a redeploy.
# ============================================================================
apiVersion: external-secrets.io/v1beta1
kind: SecretStore
metadata:
  name: aws-secrets-manager
  namespace: gitmind
spec:
  provider:
    aws:
      service: SecretsManager
      region: <your-aws-region>      # e.g. us-east-1
      auth:
        jwt:
          serviceAccountRef:
            name: gitmind-service-account   # must be annotated with IRSA role ARN
---
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: gitmind-secrets
  namespace: gitmind
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: aws-secrets-manager
    kind: SecretStore
  target:
    name: gitmind-secrets        # the Kubernetes Secret this creates/updates
    creationPolicy: Owner
  dataFrom:
    - extract:
        key: gitmind/prod/env    # the Secrets Manager secret name from step 2
