# k8s/01-secret.yaml.example
# ============================================================================
# TEMPLATE ONLY — copy to k8s/01-secret.yaml, fill in real values, and
# NEVER commit the filled-in copy. k8s/01-secret.yaml is already covered
# by .gitignore.
#
# A Kubernetes Secret is only base64-ENCODED, not encrypted, by default —
# anyone with `kubectl get secret -o yaml` access or etcd read access can
# decode it. Treat cluster RBAC as your real access boundary. For a
# production EKS cluster, prefer one of:
#   - AWS Secrets Manager + External Secrets Operator (recommended — see
#     k8s/01-secret-external.yaml.example below)
#   - AWS Secrets and Configuration Provider (ASCP) for the Secrets Store
#     CSI Driver
#   - Sealed Secrets / SOPS if you want to keep secrets in git, encrypted
#
# Quick path if you just want something working right now:
#   kubectl create secret generic gitmind-secrets \
#     --namespace=gitmind \
#     --from-env-file=.env
#
# That command reads your local .env directly — you never have to type
# secrets into a YAML file at all. Skip the rest of this file if you use it.
# ============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: gitmind-secrets
  namespace: gitmind
type: Opaque
stringData:
  NEO4J_URI: "neo4j+s://<your-instance-id>.databases.neo4j.io"
  NEO4J_USER: "neo4j"
  NEO4J_PASSWORD: "<your-neo4j-password>"
  NEO4J_DATABASE: "neo4j"

  GOOGLE_API_KEY: "<your-google-ai-api-key>"
  GITMIND_MODEL: "gemini-1.5-pro"
  GITMIND_MAX_TOKENS: "4096"
  GITMIND_TEMPERATURE: "0.0"
  GITMIND_MAX_ITERATIONS: "10"

  SNOWFLAKE_ACCOUNT: "<your-snowflake-account-id>"
  SNOWFLAKE_USER: "<your-snowflake-username>"
  SNOWFLAKE_PASSWORD: "<your-snowflake-password>"
  SNOWFLAKE_WAREHOUSE: "COMPUTE_WH"
  SNOWFLAKE_DATABASE: "GITMIND_DB"
  SNOWFLAKE_SCHEMA: "PUBLIC"
  SNOWFLAKE_ROLE: "PUBLIC"

  GITHUB_TOKEN: "<your-github-personal-access-token>"

  JIRA_URL: "https://<your-org>.atlassian.net"
  JIRA_USER: "<your-jira-account-email>"
  JIRA_API_TOKEN: "<your-jira-api-token>"
  JIRA_DEFAULT_PROJECT: "<your-default-project-key>"

  SLACK_BOT_TOKEN: "<your-slack-bot-token>"
  SLACK_SIGNING_SECRET: "<your-slack-signing-secret>"

  CORS_ALLOWED_ORIGINS: "https://your-frontend-domain.com"
